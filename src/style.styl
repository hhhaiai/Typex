body
  margin 0
  font-family -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif
  background #f5f7fb
  color #1f2937

#demo-app
  display grid
  grid-template-columns minmax(0, 1fr) minmax(320px, 420px)
  gap 24px
  padding 24px
  min-height 100vh
  box-sizing border-box

.demo-pane
  background #ffffff
  border 1px solid #dbe3f0
  border-radius 12px
  box-shadow 0 12px 32px rgba(15, 23, 42, 0.08)
  padding 20px
  box-sizing border-box

.demo-pane__header
  font-size 18px
  font-weight 600
  margin-bottom 16px

.demo-pane__label
  display block
  font-size 14px
  font-weight 600
  margin 20px 0 8px

.demo-markdown-input
  width 100%
  min-height 180px
  border 1px solid #c7d2e3
  border-radius 8px
  padding 12px
  box-sizing border-box
  resize vertical
  font inherit
  line-height 1.6

.demo-preview
  min-height 240px
  line-height 1.7
  word-break break-word

.demo-preview--empty
  color #6b7280

.demo-preview__empty
  padding 32px 0

#editor-content:focus, .custom-input:focus, .demo-markdown-input:focus
  outline none

#editor-root
  min-height 320px

#editor-content
  box-shadow #ccc 0px 20px 20px 2px
  word-break break-all
  padding 15px
  background #fff
  .custom-input-iframe
    top -100px
    left 0
    background transparent
    color transparent
    width 0px
    height 0px
    pointer-events none
    border none
    caret-color transparent
    position absolute
  .custom-caret
    top -100px
    left 0
    pointer-events none
    position absolute
    width 2px
    border none
    padding 0
    display block
    animation caret 1s infinite 0.5s steps(1, start)
  @keyframes static-caret
    0%
      opacity 1
    100%
      opacity 1
  @keyframes caret
    0%
      opacity 1
    50%
      opacity 0
    100%
      opacity 1
  .editor-disabled
    user-select none
  ::selection
    background rgb(186, 210, 250)
  table td, td
    background-color #ffffff
  table td, th, td, th, th, td
    display table-cell
    margin 0
    padding 0
    text-align left
    vertical-align middle
