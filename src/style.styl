:root
  --page-bg #eef4f7
  --page-tint #f7fafc
  --panel-bg rgba(255, 255, 255, 0.84)
  --panel-strong rgba(255, 255, 255, 0.94)
  --panel-border rgba(15, 23, 42, 0.08)
  --ink #0f172a
  --muted #617086
  --accent #2563eb
  --accent-strong #1d4ed8
  --accent-soft #dbeafe
  --hero-start #0f172a
  --hero-mid #1e3a8a
  --hero-end #0f766e
  --shadow-lg 0 28px 80px rgba(15, 23, 42, 0.16)
  --shadow-md 0 18px 44px rgba(15, 23, 42, 0.08)
  --shadow-sm 0 10px 24px rgba(15, 23, 42, 0.06)

html
  scroll-behavior smooth

body
  margin 0
  font-family 'Inter', 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif
  color var(--ink)
  background radial-gradient(circle at top, #ffffff 0%, var(--page-tint) 28%, var(--page-bg) 100%)

button, input, textarea
  font inherit

button
  color inherit

a
  color inherit

code
  font-family 'SFMono-Regular', 'Consolas', 'Liberation Mono', monospace

#site-shell
  min-height 100vh

.site-header
  position sticky
  top 0
  z-index 50
  display flex
  align-items center
  justify-content space-between
  gap 20px
  padding 18px 28px
  border-bottom 1px solid rgba(15, 23, 42, 0.06)
  backdrop-filter blur(18px)
  background rgba(247, 250, 252, 0.78)

.site-brand
  display inline-flex
  align-items center
  font-size 26px
  font-weight 800
  letter-spacing 0.04em
  text-decoration none

.site-nav
  display flex
  align-items center
  gap 10px
  flex-wrap wrap

.site-nav__link
  display inline-flex
  align-items center
  justify-content center
  min-height 44px
  padding 0 16px
  border-radius 999px
  text-decoration none
  color var(--muted)
  border 1px solid transparent
  transition transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease

.site-nav__link:hover
  color var(--ink)
  background rgba(255, 255, 255, 0.72)
  border-color rgba(15, 23, 42, 0.08)
  transform translateY(-1px)

.site-nav__link--active
  color #fff
  background linear-gradient(135deg, var(--hero-start), var(--hero-end))
  border-color transparent

.site-hero
  padding 34px 28px 18px

.site-hero__content
  max-width 1400px
  margin 0 auto
  padding 42px
  border-radius 36px
  color #f8fafc
  background linear-gradient(135deg, var(--hero-start) 0%, var(--hero-mid) 48%, var(--hero-end) 100%)
  box-shadow var(--shadow-lg)
  position relative
  overflow hidden

.site-hero__content:before
  content ''
  position absolute
  top -40px
  right -80px
  width 300px
  height 300px
  border-radius 50%
  background rgba(255, 255, 255, 0.1)
  filter blur(10px)

.site-hero__content:after
  content ''
  position absolute
  bottom -120px
  left -60px
  width 260px
  height 260px
  border-radius 50%
  background rgba(255, 255, 255, 0.08)
  filter blur(16px)

.hero-layout
  position relative
  z-index 1
  display grid
  grid-template-columns minmax(0, 1.5fr) minmax(320px, 420px)
  gap 28px
  align-items stretch

.hero-copy
  display flex
  flex-direction column
  justify-content center

.site-eyebrow
  margin 0 0 12px
  font-size 12px
  font-weight 700
  letter-spacing 0.18em
  text-transform uppercase
  color rgba(255, 255, 255, 0.7)

.hero-badge-row
  display flex
  flex-wrap wrap
  gap 10px
  margin-bottom 16px

.hero-badge
  display inline-flex
  align-items center
  min-height 34px
  padding 0 14px
  border-radius 999px
  background rgba(255, 255, 255, 0.14)
  border 1px solid rgba(255, 255, 255, 0.18)
  font-size 13px
  font-weight 700

.hero-badge--soft
  color rgba(255, 255, 255, 0.86)

.site-title
  margin 0
  max-width 900px
  font-size clamp(42px, 5vw, 72px)
  line-height 1.02

.site-subtitle
  max-width 780px
  margin 18px 0 0
  font-size 18px
  line-height 1.85
  color rgba(255, 255, 255, 0.82)

.site-chips
  display flex
  gap 12px
  flex-wrap wrap
  margin-top 24px

.site-chip
  display inline-flex
  align-items center
  min-height 38px
  padding 0 14px
  border-radius 999px
  background rgba(255, 255, 255, 0.12)
  border 1px solid rgba(255, 255, 255, 0.16)
  font-size 13px

.hero-actions
  display flex
  flex-wrap wrap
  gap 12px
  margin-top 30px

.hero-action, .mini-action
  display inline-flex
  align-items center
  justify-content center
  min-height 46px
  padding 0 18px
  border-radius 999px
  border 1px solid transparent
  text-decoration none
  transition transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease

.hero-action:hover, .mini-action:hover
  transform translateY(-1px)

.hero-action
  color var(--ink)
  background #fff
  box-shadow 0 16px 36px rgba(15, 23, 42, 0.14)

.hero-action--secondary
  color #fff
  background rgba(255, 255, 255, 0.12)
  border-color rgba(255, 255, 255, 0.18)
  box-shadow none

.hero-action--ghost
  color #fff
  background transparent
  border-color rgba(255, 255, 255, 0.2)

.hero-preview
  display grid
  gap 16px

.hero-panel
  padding 24px
  border-radius 26px
  background rgba(255, 255, 255, 0.12)
  border 1px solid rgba(255, 255, 255, 0.14)
  box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.06)

.hero-panel--glass
  backdrop-filter blur(12px)

.hero-panel--soft
  background rgba(255, 255, 255, 0.08)

.hero-panel__eyebrow
  margin 0 0 14px
  font-size 12px
  font-weight 700
  letter-spacing 0.16em
  text-transform uppercase
  color rgba(255, 255, 255, 0.68)

.hero-stats
  display grid
  gap 14px

.hero-stat strong
  display block
  font-size 18px
  margin-bottom 6px

.hero-stat span
  color rgba(255, 255, 255, 0.82)
  line-height 1.75

.hero-points
  margin 0
  padding-left 18px
  line-height 1.85
  color rgba(255, 255, 255, 0.82)

.hero-panel__actions
  display flex
  flex-wrap wrap
  gap 10px
  margin-top 18px

.mini-action
  min-height 38px
  padding 0 14px
  background rgba(255, 255, 255, 0.12)
  color #fff
  border-color rgba(255, 255, 255, 0.18)

.mini-action--ghost
  background transparent

.site-main
  max-width 1400px
  margin 0 auto
  padding 0 28px 36px

.site-view
  display none

.site-view--active
  display block

.anchor-strip
  display flex
  gap 10px
  flex-wrap wrap
  margin-bottom 20px

.anchor-pill
  display inline-flex
  align-items center
  min-height 38px
  padding 0 14px
  border-radius 999px
  text-decoration none
  color var(--accent-strong)
  background rgba(255, 255, 255, 0.82)
  border 1px solid rgba(37, 99, 235, 0.08)
  box-shadow var(--shadow-sm)

.anchor-pill:hover
  background rgba(255, 255, 255, 0.98)

.marketing-summary, .marketing-grid, .overview-grid, .compare-grid, .docs-page__grid, .api-page__intro, .hero-stats
  display grid
  gap 16px

.marketing-summary
  grid-template-columns repeat(4, minmax(0, 1fr))
  margin-bottom 28px

.marketing-grid
  grid-template-columns repeat(2, minmax(0, 1fr))

.marketing-grid--three
  grid-template-columns repeat(3, minmax(0, 1fr))

.overview-grid
  grid-template-columns repeat(3, minmax(0, 1fr))

.compare-grid
  grid-template-columns repeat(2, minmax(0, 1fr))

.summary-card, .info-card, .benefit-card, .scenario-card, .asset-card, .compare-card, .docs-card
  padding 24px
  border-radius 26px
  background var(--panel-strong)
  border 1px solid var(--panel-border)
  box-shadow var(--shadow-md)

.summary-card__label, .info-card__tag, .asset-card__tag
  margin 0 0 10px
  font-size 12px
  font-weight 700
  letter-spacing 0.14em
  text-transform uppercase
  color var(--accent)

.summary-card__value
  margin 0
  font-size 28px
  line-height 1.08

.summary-card__text, .info-card__text, .benefit-card__text, .scenario-card__text, .asset-card__text, .compare-card li, .docs-card__text
  margin 10px 0 0
  color var(--muted)
  line-height 1.82

.info-card__title, .benefit-card__title, .scenario-card__title, .asset-card__title, .compare-card__label
  margin 0
  font-size 22px
  line-height 1.2

.compare-card--muted
  background rgba(255, 255, 255, 0.72)

.compare-card--highlight, .benefit-card--large
  background linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(231, 243, 255, 0.96) 100%)
  border-color rgba(37, 99, 235, 0.14)

.marketing-section
  margin-top 28px
  padding 30px
  border-radius 30px
  background rgba(255, 255, 255, 0.7)
  border 1px solid rgba(15, 23, 42, 0.05)
  box-shadow var(--shadow-md)
  backdrop-filter blur(14px)

.marketing-section--contrast
  background linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(241, 248, 255, 0.84) 100%)

.section-heading, .docs-page__header
  display flex
  justify-content space-between
  align-items end
  gap 18px
  margin-bottom 18px

.workspace__eyebrow
  margin 0 0 8px
  font-size 12px
  font-weight 700
  letter-spacing 0.14em
  text-transform uppercase
  color var(--accent)

.workspace__title
  margin 0
  font-size 36px
  line-height 1.12

.workspace__description
  max-width 420px
  margin 0
  color var(--muted)
  line-height 1.82

.workspace__description--wide
  max-width 760px

.cta-banner
  margin-top 28px
  display flex
  align-items center
  justify-content space-between
  gap 20px
  padding 32px
  border-radius 32px
  color #f8fafc
  background linear-gradient(135deg, var(--hero-start) 0%, var(--hero-mid) 50%, var(--hero-end) 100%)
  box-shadow var(--shadow-lg)

.cta-banner .workspace__eyebrow
  color rgba(255, 255, 255, 0.72)

.cta-banner .workspace__description
  color rgba(255, 255, 255, 0.82)

.cta-banner__actions
  display flex
  flex-wrap wrap
  gap 12px

.docs-page, .api-page, .demo-page
  display grid
  gap 20px

.docs-tabs, .demo-tabs
  display inline-flex
  align-items center
  gap 10px
  width fit-content
  padding 8px
  border-radius 999px
  background rgba(255, 255, 255, 0.9)
  border 1px solid rgba(15, 23, 42, 0.08)
  box-shadow var(--shadow-md)

.docs-tab, .demo-tab
  min-height 44px
  padding 0 18px
  border 0
  border-radius 999px
  background transparent
  color var(--muted)
  font-weight 700
  cursor pointer
  transition background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease

.docs-tab:hover, .demo-tab:hover
  color var(--ink)

.docs-tab--active, .demo-tab--active
  color #fff
  background linear-gradient(135deg, var(--hero-start), var(--hero-end))
  box-shadow 0 12px 24px rgba(37, 99, 235, 0.18)

.docs-subview, .demo-subview
  display none

.docs-subview--active, .demo-subview--active
  display block

.docs-page__grid
  grid-template-columns repeat(2, minmax(0, 1fr))

.api-page__intro
  grid-template-columns repeat(2, minmax(0, 1fr))

.docs-list, .docs-links
  margin 0
  padding-left 18px
  color var(--muted)
  line-height 1.9

.docs-list--tight
  line-height 1.78

.docs-links a
  color var(--accent)
  text-decoration none

.docs-links a:hover
  text-decoration underline

.docs-code
  margin 0
  padding 16px 18px
  overflow auto
  border-radius 18px
  background #0f172a
  color #e2e8f0
  font-size 13px
  line-height 1.74

.api-page__frame-shell
  min-height 920px
  padding 14px
  border-radius 28px
  background rgba(255, 255, 255, 0.92)
  border 1px solid rgba(15, 23, 42, 0.08)
  box-shadow var(--shadow-md)

.api-page__frame
  width 100%
  min-height 890px
  border 0
  border-radius 18px
  background #fff

.demo-stage
  display grid
  gap 20px

.demo-stage--split
  grid-template-columns repeat(2, minmax(0, 1fr))

.demo-pane
  display flex
  flex-direction column
  min-width 0
  min-height 100%
  padding 22px
  border-radius 28px
  background rgba(255, 255, 255, 0.9)
  border 1px solid rgba(15, 23, 42, 0.08)
  box-shadow var(--shadow-md)

.demo-pane__head
  display flex
  justify-content space-between
  align-items end
  gap 16px
  margin-bottom 16px

.demo-pane__eyebrow
  margin 0 0 6px
  font-size 12px
  font-weight 700
  letter-spacing 0.14em
  text-transform uppercase
  color var(--accent)

.demo-pane__title
  margin 0
  font-size 24px

.demo-pane__note
  max-width 320px
  margin 0
  color var(--muted)
  line-height 1.75

.demo-pane--editor-pane #editor-root
  min-height 620px

.demo-markdown-shell, .demo-preview-shell
  flex 1
  min-height 0
  border-radius 22px
  overflow hidden
  background #fff
  border 1px solid rgba(15, 23, 42, 0.08)
  box-shadow inset 0 1px 0 rgba(255, 255, 255, 0.8)

.demo-markdown-input
  width 100%
  height 100%
  min-height 620px
  padding 20px 22px
  border 0
  box-sizing border-box
  resize none
  background #fff
  color #0f172a
  line-height 1.74
  font-size 15px
  font-family 'SFMono-Regular', 'Consolas', 'Liberation Mono', monospace
  overflow auto
  tab-size 2

.demo-markdown-input::placeholder
  color #94a3b8

.demo-preview
  min-height 100%
  padding 22px 24px 28px
  box-sizing border-box
  line-height 1.8
  color #334155
  word-break break-word

.demo-preview h1, .demo-preview h2, .demo-preview h3, .demo-preview h4
  margin 0 0 14px
  line-height 1.2
  color #0f172a

.demo-preview p
  margin 0 0 16px

.demo-preview strong
  font-weight 700

.demo-preview u
  text-decoration underline

.demo-preview del
  text-decoration line-through

.demo-preview code
  display inline-block
  padding 2px 6px
  border-radius 6px
  background rgba(15, 23, 42, 0.08)
  font-size 0.92em

.demo-preview span[style*='background']
  padding 0 2px
  border-radius 4px

.demo-preview--empty
  color #6b7280

.demo-preview__empty
  padding 32px 0

.demo-meta-grid
  margin-top 4px

.site-footer
  max-width 1400px
  margin 0 auto
  padding 0 28px 40px
  display flex
  justify-content space-between
  align-items center
  gap 18px
  color var(--muted)

.site-footer strong
  display inline-block
  margin-right 12px
  color var(--ink)

.site-footer__links
  display flex
  flex-wrap wrap
  gap 14px

.site-footer__links a
  text-decoration none

.site-footer__links a:hover
  color var(--accent)

#editor-content:focus, .custom-input:focus, .demo-markdown-input:focus
  outline none

#editor-root
  min-height 360px

#editor-content
  border-radius 20px
  border 1px solid rgba(20, 33, 61, 0.08)
  box-shadow 0 18px 34px rgba(15, 23, 42, 0.08)
  word-break break-all
  padding 16px
  background #fff
  .custom-input-iframe
    top -100px
    left 0
    background transparent
    color transparent
    width 0px
    height 0px
    pointer-events none
    border none
    caret-color transparent
    position absolute
  .custom-caret
    top -100px
    left 0
    pointer-events none
    position absolute
    width 2px
    border none
    padding 0
    display block
    animation caret 1s infinite 0.5s steps(1, start)
  @keyframes static-caret
    0%
      opacity 1
    100%
      opacity 1
  @keyframes caret
    0%
      opacity 1
    50%
      opacity 0
    100%
      opacity 1
  .editor-disabled
    user-select none
  ::selection
    background rgb(186, 210, 250)
  table td, td
    background-color #ffffff
  table td, th, td, th, th, td
    display table-cell
    margin 0
    padding 0
    text-align left
    vertical-align middle

@media (max-width: 1280px)
  .hero-layout
    grid-template-columns 1fr
  .marketing-summary
    grid-template-columns repeat(2, minmax(0, 1fr))
  .marketing-grid--three
    grid-template-columns repeat(2, minmax(0, 1fr))
  .overview-grid
    grid-template-columns 1fr
  .demo-stage--split
    grid-template-columns 1fr
  .api-page__intro
    grid-template-columns 1fr

@media (max-width: 980px)
  .site-header
    padding 16px 20px
  .site-hero
    padding 24px 20px 16px
  .site-hero__content
    padding 28px
  .site-main
    padding 0 20px 28px
  .section-heading, .docs-page__header, .demo-pane__head, .workspace__header
    display block
  .workspace__description
    max-width none
    margin-top 10px
  .marketing-summary, .marketing-grid, .marketing-grid--three, .compare-grid, .docs-page__grid
    grid-template-columns 1fr
  .cta-banner
    display block
  .cta-banner__actions
    margin-top 18px
  .docs-tabs, .demo-tabs
    width 100%
    box-sizing border-box
    flex-wrap wrap

@media (max-width: 760px)
  .site-header
    display block
  .site-brand
    margin-bottom 12px
  .site-nav
    gap 8px
  .site-nav__link
    min-height 40px
    padding 0 14px
  .site-hero
    padding 18px 16px 14px
  .site-hero__content
    padding 22px
    border-radius 28px
  .site-title
    font-size 38px
  .site-subtitle
    font-size 16px
  .hero-badge-row
    display block
  .hero-badge
    margin 0 0 8px
  .site-main
    padding 0 16px 24px
  .marketing-section
    padding 22px
    border-radius 24px
  .summary-card, .info-card, .benefit-card, .scenario-card, .asset-card, .compare-card, .docs-card, .demo-pane
    padding 18px
    border-radius 22px
  .workspace__title
    font-size 30px
  .demo-pane__title
    font-size 22px
  .demo-pane__note
    max-width none
    margin-top 10px
  .demo-pane--editor-pane #editor-root
    min-height 420px
  .demo-markdown-input
    min-height 420px
  .api-page__frame-shell
    min-height 720px
    padding 10px
  .api-page__frame
    min-height 690px
  .site-footer
    display block
    padding 0 16px 28px
  .site-footer__links
    margin-top 12px
