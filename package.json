{
  "name": "monorepo-editor",
  "version": "2.0.0",
  "description": "Typex rich text editor core monorepo with product site, docs, and SDK bundles.",
  "main": "index.js",
  "keywords": [
    "editor",
    "rich-text",
    "sdk",
    "webpack",
    "typex"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "private": true,
  "scripts": {
    "test": "jest --coverage --runInBand",
    "build": "webpack --config config/webpack.config.prod.js",
    "dev": "webpack serve --config config/webpack.config.dev.js",
    "tree": "npx treer -d ./packages/ -i modelTestDemo -e tree.txt",
    "jsdoc": "npx jsdoc -r -c jsdoc.config.json -R README.md -d deploy/api",
    "deploy": "npm run build && npm run jsdoc",
    "pack:core": "corepack pnpm --filter @typex/core run build",
    "pack:platform": "corepack pnpm --filter @typex/platform run build",
    "pack:editor": "corepack pnpm --filter editor run build",
    "pack": "npm run pack:core && npm run pack:platform && npm run pack:editor"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "babel-loader": "^10.1.0",
    "babel-plugin-transform-typex-jsx": "workspace:^",
    "clean-jsdoc-theme": "^4.3.0",
    "css-loader": "^7.1.4",
    "editor": "workspace:^",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdoc": "^4.0.5",
    "style-loader": "^4.0.0",
    "stylus": "^0.64.0",
    "stylus-loader": "^8.1.3",
    "treer": "^1.0.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1",
    "webpackbar": "^7.0.0"
  }
}
